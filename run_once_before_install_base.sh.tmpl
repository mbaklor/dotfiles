{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash

{{ if and (hasKey .chezmoi "osRelease") (eq .chezmoi.osRelease.id "fedora") -}}
{{ range .packages.linux.copr -}}
sudo dnf copr enable -y {{ . }}
{{ end }}
if [[ -f "$HOME/.bash_profile" ]] then
    rm "$HOME/.bash_profile"
fi
{{ end }}

if [["$XDG_CURRENT_DESKTOP" == "KDE"]]; then
kwriteconfig6 --file kglobalshortcutsrc --group services --group org.wezfurlong.wezterm.desktop --key _launch 'Meta+`'
fi
{{ end }}
