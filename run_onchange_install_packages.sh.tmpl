{{ if eq .chezmoi.os "linux" -}}
#!{{ .bash }}

{{ if  eq .chezmoi.osRelease.id "fedora" -}}
sudo dnf install -y {{ range .packages.linux.fedora.apps }} {{ . }} {{- end }} {{ range .packages.linux.apps }} {{ . }} {{- end }}
{{ end }}

{{ if  eq .chezmoi.osRelease.id "arch" -}}
paru -S --needed {{ range .packages.linux.arch.aur }} {{ . }} {{- end }}
sudo pacman -S --noconfirm --needed {{ range .packages.linux.arch.apps }} {{ . }} {{- end }} {{ range .packages.linux.apps }} {{ . }} {{- end }}
{{ end }}

{{ end }}
